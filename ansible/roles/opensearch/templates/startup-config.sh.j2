#!/bin/bash
# OpenSearch startup configuration script
# Reads GCE instance metadata and generates opensearch.yml at boot
set -euo pipefail

METADATA_URL="http://metadata.google.internal/computeMetadata/v1"
META_HEADER="Metadata-Flavor: Google"

CONFIG_DIR="{{ opensearch_config_dir }}"
DATA_DIR="{{ opensearch_data_dir }}"
LOG_DIR="{{ opensearch_log_dir }}"
OPENSEARCH_HOME="{{ opensearch_home }}"

get_metadata() {
  curl -sf -H "$META_HEADER" "${METADATA_URL}/instance/attributes/$1" 2>/dev/null || echo ""
}

get_instance_metadata() {
  curl -sf -H "$META_HEADER" "${METADATA_URL}/instance/$1" 2>/dev/null || echo ""
}

get_zone() {
  curl -sf -H "$META_HEADER" "${METADATA_URL}/instance/zone" | awk -F/ '{print $NF}'
}

log() {
  echo "[startup-config] $(date '+%Y-%m-%d %H:%M:%S') $*"
}

# ---------------------------------------------------------------------------
# Read metadata
# ---------------------------------------------------------------------------
NODE_ROLE=$(get_metadata "opensearch-node-role")
CLUSTER_NAME=$(get_metadata "opensearch-cluster-name")
SEED_HOSTS=$(get_metadata "opensearch-seed-hosts")
INITIAL_MASTERS=$(get_metadata "opensearch-initial-masters")
HEAP_SIZE=$(get_metadata "opensearch-heap-size")
FORCE_ZONE_AWARENESS=$(get_metadata "opensearch-force-zone-awareness")
DATA_CLUSTER_ENDPOINT=$(get_metadata "opensearch-data-cluster-endpoint")

ZONE=$(get_zone)
INSTANCE_NAME=$(hostname)
INTERNAL_IP=$(get_instance_metadata "network-interfaces/0/ip")

log "Node role: ${NODE_ROLE}"
log "Cluster name: ${CLUSTER_NAME}"
log "Zone: ${ZONE}"
log "Instance: ${INSTANCE_NAME}"

if [[ -z "$NODE_ROLE" || -z "$CLUSTER_NAME" ]]; then
  log "ERROR: opensearch-node-role and opensearch-cluster-name metadata are required"
  exit 1
fi

# ---------------------------------------------------------------------------
# Auto-calculate heap: 50% of RAM, max 31g
# ---------------------------------------------------------------------------
if [[ -z "$HEAP_SIZE" ]]; then
  TOTAL_MEM_KB=$(grep MemTotal /proc/meminfo | awk '{print $2}')
  HEAP_MB=$(( TOTAL_MEM_KB / 2 / 1024 ))
  if [[ $HEAP_MB -gt 31744 ]]; then
    HEAP_SIZE="31g"
  else
    HEAP_SIZE="${HEAP_MB}m"
  fi
fi

log "Heap size: ${HEAP_SIZE}"

sed -i "s/__HEAP_SIZE__/${HEAP_SIZE}/g" "${CONFIG_DIR}/jvm.options"

# ---------------------------------------------------------------------------
# Determine node roles
# ---------------------------------------------------------------------------
NODE_ATTR=""
ENABLE_DASHBOARDS=false
case "$NODE_ROLE" in
  master)
    NODE_ROLES="cluster_manager"
    ;;
  data)
    NODE_ROLES="data, ingest"
    ;;
  data-hot)
    NODE_ROLES="data, ingest"
    NODE_ATTR="node.attr.temp: hot"
    ;;
  coordinator)
    NODE_ROLES=""
    ;;
  master+data)
    NODE_ROLES="cluster_manager, data, ingest"
    ;;
  monitor)
    NODE_ROLES="cluster_manager, data, ingest"
    ENABLE_DASHBOARDS=true
    ;;
  dashboards)
    log "Node role is dashboards — skipping opensearch.yml generation"
    exit 0
    ;;
  *)
    log "ERROR: Unknown node role: ${NODE_ROLE}"
    exit 1
    ;;
esac

# ---------------------------------------------------------------------------
# Format and mount data disk if present
# ---------------------------------------------------------------------------
DATA_DISK="/dev/disk/by-id/google-opensearch-data"
if [[ -b "$DATA_DISK" ]]; then
  if ! blkid "$DATA_DISK" &>/dev/null; then
    log "Formatting data disk..."
    mkfs.xfs "$DATA_DISK"
  fi
  if ! mountpoint -q "$DATA_DIR"; then
    log "Mounting data disk to ${DATA_DIR}..."
    mount -o noatime "$DATA_DIR" 2>/dev/null || mount -o noatime "$DATA_DISK" "$DATA_DIR"
  fi
  chown -R opensearch:opensearch "$DATA_DIR"
fi

# ---------------------------------------------------------------------------
# Generate opensearch.yml
# ---------------------------------------------------------------------------
cat > "${CONFIG_DIR}/opensearch.yml" <<OSEOF
# Generated by startup-config.sh at $(date -u '+%Y-%m-%dT%H:%M:%SZ')
cluster.name: ${CLUSTER_NAME}
node.name: ${INSTANCE_NAME}
node.roles: [${NODE_ROLES}]
${NODE_ATTR}

network.host: 0.0.0.0
network.publish_host: ${INTERNAL_IP}

http.port: 9200
transport.port: 9300

path.data: ${DATA_DIR}
path.logs: ${LOG_DIR}

discovery.seed_hosts: [${SEED_HOSTS}]
cluster.initial_cluster_manager_nodes: [${INITIAL_MASTERS}]

# Zone awareness for HA
cluster.routing.allocation.awareness.attributes: zone
node.attr.zone: ${ZONE}

# Performance analyzer
plugins.performance_analyzer.enabled: true

# Security plugin disabled (TLS to be configured in hardening phase)
plugins.security.enabled: false
OSEOF

# Force zone awareness (prod only)
if [[ "$FORCE_ZONE_AWARENESS" == "true" ]]; then
  cat >> "${CONFIG_DIR}/opensearch.yml" <<OSEOF

# Force shard replicas across zones
cluster.routing.allocation.awareness.force.zone.values: $(echo "$SEED_HOSTS" | tr ',' '\n' | xargs -I{} basename {} | sort -u | tr '\n' ',' | sed 's/,$//')
OSEOF
fi

chown -R opensearch:opensearch "${CONFIG_DIR}"

# ---------------------------------------------------------------------------
# Enable and start the service
# ---------------------------------------------------------------------------
systemctl enable opensearch

# ---------------------------------------------------------------------------
# Configure Dashboards if monitor role (all-in-one node)
# ---------------------------------------------------------------------------
if [[ "$ENABLE_DASHBOARDS" == true ]]; then
  DASHBOARDS_CONFIG_DIR="{{ opensearch_dashboards_config_dir }}"
  log "Monitor role: configuring OpenSearch Dashboards on same node..."

  cat > "${DASHBOARDS_CONFIG_DIR}/opensearch_dashboards.yml" <<DBEOF
# Generated by startup-config.sh at $(date -u '+%Y-%m-%dT%H:%M:%SZ')
server.port: 5601
server.host: "0.0.0.0"
server.name: "${INSTANCE_NAME}"

opensearch.hosts:
  - http://localhost:9200

opensearch.ssl.verificationMode: none
opensearch_security.multitenancy.enabled: false
DBEOF

  chown -R opensearch:opensearch "${DASHBOARDS_CONFIG_DIR}"
  systemctl enable opensearch-dashboards
  log "Dashboards configured to connect to local OpenSearch instance."
fi

log "Configuration complete. OpenSearch will start via systemd."
