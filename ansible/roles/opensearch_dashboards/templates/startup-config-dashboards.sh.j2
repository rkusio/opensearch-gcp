#!/bin/bash
# OpenSearch Dashboards startup configuration script
# Reads GCE instance metadata and generates opensearch_dashboards.yml at boot
set -euo pipefail

METADATA_URL="http://metadata.google.internal/computeMetadata/v1"
META_HEADER="Metadata-Flavor: Google"

CONFIG_DIR="{{ opensearch_dashboards_config_dir }}"
DASHBOARDS_HOME="{{ opensearch_dashboards_home }}"

get_metadata() {
  curl -sf -H "$META_HEADER" "${METADATA_URL}/instance/attributes/$1" 2>/dev/null || echo ""
}

log() {
  echo "[startup-config-dashboards] $(date '+%Y-%m-%d %H:%M:%S') $*"
}

NODE_ROLE=$(get_metadata "opensearch-node-role")
OPENSEARCH_HOSTS=$(get_metadata "opensearch-dashboards-hosts")
SERVER_HOST=$(get_metadata "opensearch-dashboards-server-host")

if [[ "$NODE_ROLE" != "dashboards" && "$NODE_ROLE" != "monitor" ]]; then
  log "Node role is ${NODE_ROLE} — skipping Dashboards configuration"
  exit 0
fi

# Monitor role: Dashboards is configured by startup-config.sh (connects to localhost)
if [[ "$NODE_ROLE" == "monitor" ]]; then
  log "Monitor role — Dashboards configured by opensearch startup-config.sh, skipping."
  exit 0
fi

if [[ -z "$OPENSEARCH_HOSTS" ]]; then
  log "ERROR: opensearch-dashboards-hosts metadata is required for dashboards role"
  exit 1
fi

SERVER_HOST="${SERVER_HOST:-0.0.0.0}"

# Convert comma-separated hosts to YAML array format
IFS=',' read -ra HOSTS <<< "$OPENSEARCH_HOSTS"
HOSTS_YAML=""
for host in "${HOSTS[@]}"; do
  HOSTS_YAML="${HOSTS_YAML}  - ${host}\n"
done

log "Generating opensearch_dashboards.yml..."

cat > "${CONFIG_DIR}/opensearch_dashboards.yml" <<DBEOF
# Generated by startup-config-dashboards.sh at $(date -u '+%Y-%m-%dT%H:%M:%SZ')
server.port: 5601
server.host: "${SERVER_HOST}"
server.name: "$(hostname)"

opensearch.hosts:
$(echo -e "$HOSTS_YAML")

opensearch.ssl.verificationMode: none
opensearch_security.multitenancy.enabled: false
DBEOF

chown -R opensearch:opensearch "${CONFIG_DIR}"

systemctl enable opensearch-dashboards
log "Dashboards configuration complete."
